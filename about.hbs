<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Third-Party Licenses — Particle Life</title>
    <style>
        @media (prefers-color-scheme: dark) {
            body {
                background: #333;
                color: white;
            }
            a {
                color: skyblue;
            }
        }
        .container {
            font-family: sans-serif;
            max-width: 800px;
            margin: 0 auto;
        }
        .intro {
            text-align: center;
        }
        .embedded-assets {
            background: #f0f4ff;
            border-left: 4px solid #0066cc;
            padding: 0.6rem 1rem;
            margin-bottom: 1.5rem;
        }
        @media (prefers-color-scheme: dark) {
            .embedded-assets {
                background: #1a2a44;
                border-left-color: skyblue;
            }
        }
        .licenses-list {
            list-style-type: none;
            margin: 0;
            padding: 0;
        }
        .license-used-by {
            margin-top: -10px;
        }
        .license-text {
            max-height: 200px;
            overflow-y: scroll;
            white-space: pre-wrap;
        }
    </style>
</head>

<body>
    <main class="container">
        <div class="intro">
            <h1>Third-Party Licenses — Particle Life</h1>
            <p>This page lists the licenses of all third-party dependencies used in Particle Life.</p>
        </div>

        <h2>Embedded Assets</h2>
        <div class="embedded-assets">
            <p>The following third-party color palettes are embedded directly in the source code.
            They are not distributed as Cargo crates and therefore do not appear in the
            dependency section below.</p>
            <ul>
                <li><strong>Nord palette</strong> — Arctic Ice Studio —
                    <a href="https://www.nordtheme.com">nordtheme.com</a> — MIT License</li>
                <li><strong>Catppuccin Mocha palette</strong> — Catppuccin org —
                    <a href="https://catppuccin.com">catppuccin.com</a> — MIT License</li>
            </ul>
        </div>

        <h2>Overview of Cargo dependency licenses:</h2>
        <ul class="licenses-overview">
            {{#each overview}}
            <li><a href="#{{id}}">{{name}}</a> ({{count}})</li>
            {{/each}}
        </ul>

        <h2>All license text:</h2>
        <ul class="licenses-list">
            {{#each licenses}}
            <li class="license">
                <h3 id="{{id}}">{{name}}</h3>
                <h4>Used by:</h4>
                <ul class="license-used-by">
                    {{#each used_by}}
                    <li><a href="{{#if crate.repository}} {{crate.repository}} {{else}} https://crates.io/crates/{{crate.name}} {{/if}}">{{crate.name}} {{crate.version}}</a></li>
                    {{/each}}
                </ul>
                <pre class="license-text">{{text}}</pre>
            </li>
            {{/each}}
        </ul>
    </main>
</body>

</html>
